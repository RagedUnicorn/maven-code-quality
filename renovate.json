{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended"
  ],
  "schedule": [
    "on monday"
  ],
  "timezone": "UTC",
  "labels": [
    "dependencies",
    "renovate"
  ],
  "commitMessagePrefix": "chore(deps):",
  "prConcurrentLimit": 2,
  "prCreation": "immediate",
  "automerge": false,
  "packageRules": [
    {
      "matchManagers": [
        "maven"
      ],
      "groupName": "ragedunicorn maven plugins",
      "description": "Group all ragedunicorn Maven plugin updates",
      "matchPackageNames": [
        "/^com.ragedunicorn.tools.maven/"
      ]
    },
    {
      "matchManagers": [
        "github-actions"
      ],
      "groupName": "github actions",
      "description": "Group all GitHub Actions updates"
    }
  ],
  "maven": {
    "managerFilePatterns": [
      "/^pom\\.xml$/"
    ]
  },
  "github-actions": {
    "managerFilePatterns": [
      "/^\\.github/workflows/.*\\.ya?ml$/"
    ]
  },
  "prBodyDefinitions": {
    "Package": "{{depName}}",
    "Type": "{{depType}}",
    "Change": "{{updateType}}",
    "Current": "{{currentVersion}}",
    "New": "{{newVersion}}",
    "Age": "{{age}}",
    "Adoption": "{{adoption}}",
    "Passing": "{{passing}}",
    "Confidence": "{{confidence}}"
  },
  "postUpdateOptions": []
}